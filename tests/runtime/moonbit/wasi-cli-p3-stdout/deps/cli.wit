package wasi:cli@0.3.0;

interface types {
  enum error-code {
    io,
    illegal-byte-sequence,
    pipe,
  }
}

interface stdout {
  use types.{error-code};

  write-via-stream: func(data: stream<u8>) -> future<result<_, error-code>>;
}

interface run {
  run: async func() -> result;
}

world command {
  import types;
  import stdout;

  export run;
}
