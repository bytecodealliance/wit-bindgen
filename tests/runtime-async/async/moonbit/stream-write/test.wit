package my:test;

interface i {
  resource thing {
    constructor(value: u32);
    value: func() -> u32;
  }

  // MoonBit creates a stream, writes values, and returns it
  create-stream-with-values: async func(count: u32) -> stream<u32>;
  // MoonBit creates a unit stream
  create-unit-stream: async func(count: u32) -> stream;
  // MoonBit creates a local stream, returns it, and observes whether the rest
  // of the write completes after the caller closes the read end.
  create-bridge-stream-with-signal: async func(signal: future) -> tuple<stream<u32>, future<bool>>;
  // Same as above, but for unit streams to cover the unit-specific lowering
  // path.
  create-bridge-unit-stream-with-signal: async func(signal: future) -> tuple<stream, future<bool>>;
  active-things: func() -> u32;
  create-bridge-thing-stream-with-signal: async func(signal: future) -> tuple<stream<thing>, future<bool>>;
}

world test {
  export i;
}

world runner {
  import i;

  export run: async func();
}
